#!/usr/bin/env bash
# bd hook: on_create — fires after `bd create "title"`
# Args: $1=issue_id  $2=event_type ("created")
# Stdin: JSON issue object

ISSUE_ID="$1"
ISSUE_JSON=$(cat)

SERVER="${PIXEL_AGENTS_SERVER:-http://localhost:3001}"
SESSION="${PIXEL_AGENTS_SESSION:-}"
AGENT_ID="${PIXEL_AGENTS_AGENT_ID:-$(git config user.name 2>/dev/null || echo "${USER:-agent}")}"

TITLE=$(printf '%s' "$ISSUE_JSON" | python3 -c \
  "import sys,json; d=json.load(sys.stdin); print(d.get('title','')[:50])" 2>/dev/null || echo "")

LABEL="bd: planning ${ISSUE_ID}"
if [ -n "$TITLE" ]; then
  LABEL="bd: planning – ${TITLE}"
fi

curl -sf -X POST "${SERVER}/event" \
  -H "Content-Type: application/json" \
  -d "{\"sessionId\":\"${SESSION}\",\"type\":\"setWorking\",\"agentId\":\"${AGENT_ID}\",\"label\":\"${LABEL}\"}" \
  >/dev/null 2>&1 || true
