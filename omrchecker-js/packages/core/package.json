{
  "name": "@omrchecker/core",
  "version": "0.1.0",
  "description": "OMRChecker core library - TypeScript implementation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.config.browser.ts",
    "test:all": "npm run test:unit && npm run test:browser",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:watch:browser": "vitest --config vitest.config.browser.ts",
    "coverage": "vitest run --coverage",
    "coverage:unit": "vitest run --coverage --config vitest.config.ts",
    "coverage:browser": "vitest run --coverage --config vitest.config.browser.ts",
    "coverage:all": "npm run coverage:unit && npm run coverage:browser",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "omr",
    "optical-mark-recognition",
    "computer-vision",
    "opencv"
  ],
  "author": "OMRChecker Contributors",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.58.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@techstark/opencv-js": "4.9.0-release.3",
    "zod": "^3.22.4"
  }
}
