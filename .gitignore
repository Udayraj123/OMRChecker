# Any directory starting with a dot
**/\.*/

# Exceptions for dot directories -
!.github/
!.vscode/
!.devcontainer/
!docs/overrides/.icons

# mkdocs generated site
docs/site

# Everything in inputs/ and outputs/
inputs/*
outputs/*

# Misc
**/.DS_Store
**/__ignore__
**/__pycache__
venv/
.venv/
OMRChecker.wiki/

# Node.js dependencies - exclude everywhere
**/node_modules/

# TypeScript/JavaScript build outputs
**/dist/
**/.vite/
**/build/

# pnpm
pnpm-lock.yaml
.pnpm-store/

# pytest
pytestdebug.log
.coverage
.pytest_cache

# ruff
.ruff_cache

# ML outputs
runs/**/*
*.pt

# Sync tool reports
reports/sync-status-*.html
.sync-suggestions/