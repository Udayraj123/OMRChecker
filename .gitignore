# Any directory starting with a dot
**/\.*/

# Exceptions for dot directories -
!.github/
!.vscode/
!.devcontainer/
!docs/overrides/.icons

# mkdocs generated site
docs/site

# Everything in inputs/ and outputs/
inputs/*
outputs/*

# Misc
**/.DS_Store
**/__ignore__
**/__pycache__
venv/
.venv/
OMRChecker.wiki/

# TypeScript/JavaScript build outputs
omrchecker-js/**/dist/
omrchecker-js/**/node_modules/
omrchecker-js/**/.vite/
omrchecker-js/**/build/
change-propagation-tool/dist/
change-propagation-tool/node_modules/
change-propagation-tool/.vite/
code-browser/dist/
code-browser/node_modules/

# pnpm
pnpm-lock.yaml
.pnpm-store/

# pytest
pytestdebug.log
.coverage
.pytest_cache

# ruff
.ruff_cache

# ML outputs
runs/**/*
*.pt

# Sync tool reports
reports/sync-status-*.html
.sync-suggestions/